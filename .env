# shellcheck shell=bash

# Add a path to $PATH if it exists and not already in $PATH
function add_to_path() {
	if [[ -d $1 ]] && [[ -r $1 ]] && [[ ":$PATH:" != *":$1:"* ]]; then
		export PATH="${PATH:+"$PATH:"}$1"
	fi
}

export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

add_to_path "$HOME/bin"
add_to_path "$HOME/.local/bin"

case "$(uname -s)" in
Darwin)
	HOMEBREW_PREFIX="/opt/homebrew"
	;;
Linux)
	HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"
	;;
*)
	HOMEBREW_PREFIX=
	;;
esac

test -d "$HOMEBREW_PREFIX" && eval "$("$HOMEBREW_PREFIX/bin/brew" shellenv)"

if command -v go >/dev/null; then
	# https://github.com/actions/setup-go/issues/27#issuecomment-549102955
	add_to_path "$(go env GOPATH)/bin"
fi

if command -v bat >/dev/null; then
	# If bat is installed, use it for manual pages to get colored output.
	# https://askubuntu.com/a/1506718
	export MANPAGER="sh -c 'col -bx | bat -l man --plain --paging=always'"
	export MANROFFOPT="-c"
else
	# Don't clear the screen after quitting a manual page (Default behavior when using bat)
	export MANPAGER="less -X"
fi

if command -v nvim >/dev/null; then
	export EDITOR="nvim"
elif command -v vim >/dev/null; then
	export EDITOR="vim"
else
	export EDITOR="vi"
fi

set -o emacs
